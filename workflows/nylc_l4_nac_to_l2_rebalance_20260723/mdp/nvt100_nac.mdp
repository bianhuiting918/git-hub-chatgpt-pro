define                   = -DPOSRES_WEAK -DPOSRES_L2_100
integrator               = md
nsteps                   = 20000
continuation             = no
dt                       = 0.001
constraints              = h-bonds
constraint-algorithm     = lincs
lincs-iter               = 2
lincs-order              = 6
cutoff-scheme            = Verlet
nstlist                  = 20
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres
pbc                      = xyz
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 0.5
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstxout-compressed       = 100
compressed-x-precision   = 1000
nstenergy                = 100
nstlog                   = 100
ref-t                    = 100
pcoupl                   = no
gen-vel                  = yes
gen-temp                 = 100
gen-seed                 = 20260724
