cutoff-scheme            = Verlet
nstlist                  = 1
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres
pbc                      = xyz
constraints              = none
nstenergy                = 10
nstlog                   = 10
