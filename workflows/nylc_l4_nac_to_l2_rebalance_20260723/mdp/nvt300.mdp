define                   = -DPOSRES_L2_100
integrator               = md
nsteps                   = 100000
continuation             = yes
dt                       = 0.002
constraints              = h-bonds
constraint-algorithm     = lincs
lincs-iter               = 1
lincs-order              = 4
cutoff-scheme            = Verlet
nstlist                  = 20
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres
pbc                      = xyz
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 0.5
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstxout-compressed       = 1000
compressed-x-precision   = 1000
nstenergy                = 500
nstlog                   = 500
ref-t                    = 300
pcoupl                   = no
gen-vel                  = no
