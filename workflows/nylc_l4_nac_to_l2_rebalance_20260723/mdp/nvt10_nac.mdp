define                   = -DPOSRES_WEAK -DPOSRES_L2_500
integrator               = md
nsteps                   = 4000
continuation             = no
dt                       = 0.0005
constraints              = h-bonds
constraint-algorithm     = lincs
lincs-iter               = 2
lincs-order              = 6
cutoff-scheme            = Verlet
nstlist                  = 20
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres
pbc                      = xyz
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 0.1
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstxout-compressed       = 20
compressed-x-precision   = 1000
nstenergy                = 20
nstlog                   = 20
ref-t                    = 10
pcoupl                   = no
gen-vel                  = yes
gen-temp                 = 10
gen-seed                 = 20260724
