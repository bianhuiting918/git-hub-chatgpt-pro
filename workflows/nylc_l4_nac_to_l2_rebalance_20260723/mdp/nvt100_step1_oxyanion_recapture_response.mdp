integrator               = md
dt                       = 0.001
nsteps                   = 50000
continuation             = no
constraints              = h-bonds
constraint-algorithm     = lincs
lincs-iter               = 2
lincs-order              = 6
cutoff-scheme            = Verlet
nstlist                  = 20
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 0.2
ref-t                    = 100
pcoupl                   = no
pbc                      = xyz
gen-vel                  = yes
gen-temp                 = 100
gen-seed                 = 267210
comm-mode                = Linear
nstcomm                  = 100
nstxout                   = 0
nstvout                   = 0
nstfout                   = 0
nstxout-compressed       = 100
compressed-x-precision   = 1000
nstenergy                = 100
nstlog                   = 100
pull                     = yes
pull-ngroups             = 7
pull-ncoords             = 6
pull-group1-name         = Thr267_OG1
pull-group2-name         = L2_C12
pull-group3-name         = L2_O2
pull-group4-name         = Tyr146_N
pull-group5-name         = Tyr146_H
pull-group6-name         = Asn219_ND2
pull-group7-name         = Asn219_HD21

pull-coord1-type         = umbrella
pull-coord1-geometry     = distance
pull-coord1-groups       = 1 2
pull-coord1-start        = no
pull-coord1-init         = 0.330000
pull-coord1-rate         = 0.000000
pull-coord1-k            = 2000

pull-coord2-type         = umbrella
pull-coord2-geometry     = angle
pull-coord2-groups       = 2 1 2 3
pull-coord2-start        = no
pull-coord2-init         = 105.000000
pull-coord2-rate         = 0.000000
pull-coord2-k            = 100

pull-coord3-type         = umbrella
pull-coord3-geometry     = distance
pull-coord3-groups       = 5 3
pull-coord3-start        = yes
pull-coord3-init         = 0
pull-coord3-rate         = -0.001000
pull-coord3-k            = 500

pull-coord4-type         = umbrella
pull-coord4-geometry     = angle
pull-coord4-groups       = 5 4 5 3
pull-coord4-start        = no
pull-coord4-init         = 160.000000
pull-coord4-rate         = 0.000000
pull-coord4-k            = 50

pull-coord5-type         = umbrella
pull-coord5-geometry     = distance
pull-coord5-groups       = 7 3
pull-coord5-start        = yes
pull-coord5-init         = 0
pull-coord5-rate         = -0.001000
pull-coord5-k            = 500

pull-coord6-type         = umbrella
pull-coord6-geometry     = angle
pull-coord6-groups       = 7 6 7 3
pull-coord6-start        = no
pull-coord6-init         = 160.000000
pull-coord6-rate         = 0.000000
pull-coord6-k            = 50

pull-nstxout             = 100
pull-nstfout             = 100
