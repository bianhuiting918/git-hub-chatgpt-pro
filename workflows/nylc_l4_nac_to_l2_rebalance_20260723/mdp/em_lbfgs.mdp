define                   = -DPOSRES_L2_1000 -DFLEXIBLE
integrator               = l-bfgs
emtol                    = 500.0
emstep                   = 0.001
nsteps                   = 50000
cutoff-scheme            = Verlet
nstlist                  = 1
rlist                    = 1.0
coulombtype              = PME
rcoulomb                 = 1.0
vdwtype                  = PME
lj-pme-comb-rule         = Geometric
rvdw                     = 1.0
DispCorr                 = EnerPres
pbc                      = xyz
constraints              = none
nstenergy                = 100
nstlog                   = 100
